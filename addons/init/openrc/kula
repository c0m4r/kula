#!/sbin/openrc-run
# Kula - Lightweight Linux Server Monitor

name="kula"
description="Kula server monitoring daemon"

command="/usr/bin/kula"
command_args="--config /etc/kula/config.yaml serve"
command_user="kula:kula"
command_background=true

pidfile="/run/${RC_SVCNAME}.pid"
directory="/var/lib/kula"

depend() {
    need net
    after firewall
}

start_pre() {
    checkpath --directory --owner kula:kula --mode 0755 /var/lib/kula
    # Runtime dir for an optional Unix socket under /run/kula (web.unix_socket).
    # /run is a tmpfs wiped each boot and kula does not create the socket's
    # parent dir itself. Unused in the default TCP setup; harmless if so.
    checkpath --directory --owner kula:kula --mode 0750 /run/kula
}
